# Copia este archivo como  .env  (sin .example) y completa los valores.
# NUNCA subas el .env a GitHub (ya está en .gitignore).

# --- Lector de precios desde la BD (OPCIONAL) ---
# Si la anon key está bloqueada por RLS, usa la service_role (server-side, salta RLS).
# Esta llave es SECRETA: solo va aquí (local), NUNCA al cliente ni a GitHub.
# Sácala de: Supabase Dashboard > Project Settings > API > service_role
# SUPABASE_URL=https://ybonpeapvpdseqbtlysx.supabase.co
# SUPABASE_SERVICE_KEY=

# --- Descripciones con IA (OPCIONAL, de pago) ---
# Llave en https://console.anthropic.com -> API Keys
# Si la dejas vacía, los captions se generan GRATIS con plantillas.
ANTHROPIC_API_KEY=

# --- Publicar en Instagram: CONECTAR CON 1 CLIC (recomendado) ---
# Pones App ID + Secret aquí, reinicias el panel, y le das al boton
# "Conectar Instagram" del Estudio. El OAuth guarda el token solo (60 dias).
# App de Meta -> Configuracion -> Basica (App ID + Clave secreta)
FB_APP_ID=
FB_APP_SECRET=
# Agrega esta URL en tu app -> Inicio de sesion con Facebook -> URI de redireccionamiento validos:
#   http://localhost:8000/api/fb-callback
# (opcional, solo si cambias el puerto)
# FB_REDIRECT_URI=http://localhost:8000/api/fb-callback

# --- Alternativa manual (si prefieres pegar el token a mano) ---
# IG_TOKEN=
# IG_USER_ID=

# 3) URL pública donde viven las piezas (Instagram las baja desde ahí).
#    Tu propia app de Vercel ya las sirve -> incluye /marketing al final:
#    OJO: cada vez que generas piezas nuevas, hay que hacer git push
#    para que Vercel las despliegue antes de publicar (~1 min).
PUBLIC_BASE_URL=https://el-maravilloso-final.vercel.app/marketing
