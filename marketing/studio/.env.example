# Copia este archivo como  .env  (sin .example) y completa los valores.
# NUNCA subas el .env a GitHub (ya está en .gitignore).

# --- Descripciones con IA (OPCIONAL, de pago) ---
# Llave en https://console.anthropic.com -> API Keys
# Si la dejas vacía, los captions se generan GRATIS con plantillas.
ANTHROPIC_API_KEY=

# --- Publicar en Instagram (Graph API) ---
# 1) Token: developers.facebook.com -> tu app -> Graph API Explorer
#    Permisos: instagram_basic, instagram_content_publish, pages_show_list,
#    pages_read_engagement, business_management. Usa token de larga duración.
IG_TOKEN=

# 2) Tu Instagram Business Account ID.
#    Con el token puesto, abre:  http://127.0.0.1:8000/api/ig-id  y cópialo.
IG_USER_ID=

# 3) URL pública donde viven las piezas (Instagram las baja desde ahí).
#    Ej: https://el-maravilloso-final.vercel.app   (sin barra final)
#    Las rutas quedan así: {PUBLIC_BASE_URL}/content/tiktok/xxx.mp4
PUBLIC_BASE_URL=
